{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey":   "QuantityMeasurementApp_SuperSecretKey_AtLeast32Chars!",
    "Issuer":      "QuantityMeasurementApi",
    "Audience":    "QuantityMeasurementApiUsers",
    "ExpiryHours": "24"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/v1/users/{**catch-all}" }
      },
      "qma-route": {
        "ClusterId": "qma-cluster",
        "Match": { "Path": "/api/v1/quantities/{**catch-all}" },
        "AuthorizationPolicy": "default"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": { "Address": "http://auth-service:8080" }
        }
      },
      "qma-cluster": {
        "Destinations": {
          "qma-service": { "Address": "http://qma-service:8080" }
        }
      }
    }
  }
}
