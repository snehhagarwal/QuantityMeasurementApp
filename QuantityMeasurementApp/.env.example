# Copy this file to .env and fill in your values

# Database
DB_PASSWORD=yourpassword
USE_DATABASE=PostgreSQL

# JWT — must be identical across all services
JWT_SECRET_KEY=QuantityMeasurementApp_SuperSecretKey_AtLeast32Chars!
JWT_ISSUER=QuantityMeasurementApi
JWT_AUDIENCE=QuantityMeasurementApiUsers
JWT_EXPIRY_HOURS=24

# AES encryption (auth-service)
ENCRYPTION_KEY=QuantityMeasurementApp_AES_EncryptionKey_AtLeast32Chars!

# Google OAuth (auth-service)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
